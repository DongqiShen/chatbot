# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

OPENAI_API_KEY=****
OPENAI_BASE_URL=****
OPENAI_MODEL=****
LOG_FILE=
# LOG_PROFILE controls default logging behavior.
# development: debug logs + user/model/tool summaries enabled
# production: info logs + sensitive summaries disabled
# diagnostic: info logs + user/model/tool summaries enabled
LOG_PROFILE=production
# Explicit flags below override LOG_PROFILE when set.
LOG_LEVEL=
LOG_USER_MESSAGES=false
LOG_MODEL_IO=false
LOG_TOOL_CALLS=false
